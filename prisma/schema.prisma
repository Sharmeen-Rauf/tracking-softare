datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum Platform {
  INSTAGRAM
  YOUTUBE
  TIKTOK
  FACEBOOK
}

model User {
  id           String         @id @default(uuid())
  name         String
  email        String         @unique
  passwordHash String
  role         Role           @default(EMPLOYEE)
  accounts     ClientAccount[] // Managed accounts (for Employees)
  submissions  Submission[]    // Submissions entered by this user
  scheduledPosts ScheduledPost[] // Posts scheduled by this user
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model ClientAccount {
  id              String          @id @default(uuid())
  name            String
  employeeId      String
  employee        User            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  submissions     Submission[]
  
  // Encrypted OAuth Tokens for Poster Bot
  encryptedToken  String?         // Encrypted Meta or TikTok Access Token
  encryptedRefresh String?        // Encrypted TikTok Refresh Token
  tokenIv         String?         // IV used for Access Token encryption
  tokenTag        String?         // GCM tag for Access Token
  tokenExpiresAt  DateTime?       // Access Token expiration datetime
  
  scheduledPosts  ScheduledPost[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([name, employeeId]) // Ensure unique client account name per employee
}

enum PublishStatus {
  PENDING
  PUBLISHING
  PUBLISHED
  FAILED
}

model ScheduledPost {
  id              String        @id @default(uuid())
  mediaUrl        String
  caption         String        @db.Text
  platform        Platform
  scheduledTime   DateTime
  status          PublishStatus @default(PENDING)
  attempts        Int           @default(0)
  errorMessage    String?       @db.Text
  
  clientAccountId String
  clientAccount   ClientAccount @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)
  createdById     String
  createdBy       User          @relation(fields: [createdById], references: [id], onDelete: Cascade)
  
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status, scheduledTime])
}

model Submission {
  id              String         @id @default(uuid())
  url             String         @unique // Critical for global uniqueness checking
  platform        Platform
  clientAccountId String
  clientAccount   ClientAccount  @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)
  submittedById   String
  submittedBy     User           @relation(fields: [submittedById], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())
}
